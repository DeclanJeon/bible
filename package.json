{
  "name": "bible-hyperlink-companion",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "benchmark:ko": "node scripts/run-korean-prompt-benchmark.mjs --fixture qa/korean-prompt-benchmark.json --locale ko",
    "benchmark:en": "node scripts/run-korean-prompt-benchmark.mjs --fixture qa/english-prompt-benchmark.json --locale en",
    "benchmark": "npm run benchmark:ko && npm run benchmark:en",
    "deploy:ponslink": "bash scripts/deploy-ponslink.sh",
    "ingest:crossrefs": "python3 scripts/ingest_openbible_crossrefs.py",
    "ingest:phrases": "python3 scripts/ingest_phrase_crossrefs.py"
  },
  "dependencies": {
    "lucide-react": "^1.18.0",
    "next": "^15.5.19",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.19",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.17",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "postcss": "^8.5.15"
  }
}
